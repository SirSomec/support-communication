# Copy to production.env outside version control and replace every REQUIRED value.
# This file is a schema/example only. The application rejects known local and placeholder credentials in production.

APP_DOMAIN=support.example.com
ACME_EMAIL=ops@example.com

FRONTEND_IMAGE=ghcr.io/example/support-communication-frontend:sha-REQUIRED
API_IMAGE=ghcr.io/example/support-communication-api:sha-REQUIRED
MIGRATION_IMAGE=ghcr.io/example/support-communication-migrations:sha-REQUIRED

DATABASE_URL=postgresql://runtime:REQUIRED@db.example.internal:5432/support_communication?connection_limit=5&pool_timeout=30
REDIS_URL=rediss://:REQUIRED@redis.example.internal:6379

S3_ENDPOINT=https://s3.example.com
S3_BUCKET=support-communication-production
S3_REGION=us-east-1
S3_ACCESS_KEY=REQUIRED
S3_SECRET_KEY=REQUIRED
S3_PUBLIC_UPLOAD_BASE=https://s3.example.com
CLAMAV_ALLOWED_DOWNLOAD_ORIGINS=https://s3.example.com

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=REQUIRED
MAIL_PASSWORD=REQUIRED
MAIL_FROM=noreply@example.com
MFA_OTP_SMTP_FROM=noreply@example.com
PUBLIC_DEMO_NOTIFICATION_SMTP_TO=support@example.com

DEMO_SERVICE_ADMIN_KEY=REQUIRED
JWT_ACCESS_SECRET=REQUIRED
JWT_REFRESH_SECRET=REQUIRED
PUBLIC_API_KEY_SECRET=REQUIRED
PROVIDER_CREDENTIAL_MASTER_KEY=REQUIRED_BASE64_32_BYTES
AI_CONNECTIONS_MASTER_KEY=REQUIRED_BASE64_32_BYTES
FILE_SCAN_CALLBACK_TOKEN=REQUIRED
OUTBOX_SCANNER_BEARER_TOKEN=REQUIRED
WEBHOOK_DELIVERY_SIGNING_SECRET=REQUIRED

# Comma-separated exact origins, without paths. Empty means same-origin only.
CORS_ALLOWED_ORIGINS=https://customer.example.com

# Set only for the controlled first API start, then remove both and recreate the container.
BOOTSTRAP_SERVICE_ADMIN_EMAIL=
BOOTSTRAP_SERVICE_ADMIN_PASSWORD=

BROWSER_PUSH_ENABLED=false
NOTIFICATION_DELIVERY_PROVIDER_MODE=disabled
TELEGRAM_POLLING_ENABLED=false
BILLING_SYNC_PROVIDER_MODE=disabled

# Optional but strongly recommended independent immutable backup destination.
BACKUP_OFFSITE_ENDPOINT=https://backup-s3.example.net
BACKUP_OFFSITE_BUCKET=support-communication-backups
BACKUP_OFFSITE_ACCESS_KEY=REQUIRED
BACKUP_OFFSITE_SECRET_KEY=REQUIRED
