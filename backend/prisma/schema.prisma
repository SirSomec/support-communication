generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String             @id
  name        String
  status      String
  healthScore Int?               @map("health_score")
  metadata    Json?              @map("metadata")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  auditEvents TenantAuditEvent[]
  users       TenantUser[]

  @@map("tenants")
}

model TenantAuditEvent {
  id       String   @id
  tenantId String   @map("tenant_id")
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action   String
  actor    String
  at       DateTime @db.Timestamptz(3)
  immutable Boolean  @default(true)
  reason   String?
  result   String
  severity String
  target   String
  traceId  String   @map("trace_id")

  @@index([tenantId, at], map: "tenant_audit_events_tenant_id_at_idx")
  @@map("tenant_audit_events")
}

model TenantUser {
  id           String    @id
  tenantId     String    @map("tenant_id")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String
  role         String
  status       String
  mfa          String    @map("mfa_status")
  inviteStatus String    @map("invite_status")
  lastActiveAt DateTime? @map("last_active_at") @db.Timestamptz(3)
  sessions     Int       @default(0) @map("active_sessions")
  risk         String
  device       String
  supportNotes String    @map("support_notes")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([tenantId, email], map: "tenant_users_tenant_id_email_key")
  @@index([tenantId, status], map: "tenant_users_tenant_id_status_idx")
  @@index([email], map: "tenant_users_email_idx")
  @@map("tenant_users")
}

model PermissionRole {
  id          String   @id @default(cuid())
  key         String   @unique(map: "permission_roles_key_key")
  description String?
  actions     String[] @default([])
  aliases     String[] @default([])
  groupIds    String[] @default([]) @map("group_ids")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("permission_roles")
}

model RbacPolicyVersion {
  id          String    @id
  version     String
  status      String
  description String
  checksum    String
  createdBy   String    @map("created_by")
  createdAt   DateTime  @map("created_at") @db.Timestamptz(3)
  activatedAt DateTime? @map("activated_at") @db.Timestamptz(3)

  @@index([status, activatedAt], map: "rbac_policy_versions_status_activated_at_idx")
  @@map("rbac_policy_versions")
}

model RbacRoleGrant {
  id              String   @id
  policyVersionId String   @map("policy_version_id")
  roleKey         String   @map("role_key")
  tenantId        String?  @map("tenant_id")
  action          String
  resource        String
  effect          String
  createdBy       String   @map("created_by")
  createdAt       DateTime @map("created_at") @db.Timestamptz(3)
  traceId         String   @map("trace_id")

  @@index([policyVersionId, tenantId, roleKey, action, resource], map: "rbac_role_grants_policy_tenant_role_action_idx")
  @@index([roleKey, action], map: "rbac_role_grants_role_action_idx")
  @@map("rbac_role_grants")
}

model PermissionDenialEvent {
  id              String   @id
  tenantId        String?  @map("tenant_id")
  actorId         String?  @map("actor_id")
  roleKey         String?  @map("role_key")
  action          String
  resource        String
  policyVersionId String?  @map("policy_version_id")
  reason          String
  at              DateTime @db.Timestamptz(3)
  traceId         String   @map("trace_id")
  immutable       Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([tenantId, action, at], map: "permission_denial_events_tenant_action_at_idx")
  @@index([policyVersionId, at], map: "permission_denial_events_policy_at_idx")
  @@map("permission_denial_events")
}

model ServiceAdminAuditEvent {
  id        String   @id
  action    String
  actor     String
  actorName String   @map("actor_name")
  at        DateTime @db.Timestamptz(3)
  immutable Boolean  @default(true)
  reason    String?
  result    String
  severity  String
  target    String
  tenantId  String?  @map("tenant_id")
  traceId   String   @map("trace_id")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([userId, at], map: "service_admin_audit_events_user_id_at_idx")
  @@index([tenantId, at], map: "service_admin_audit_events_tenant_id_at_idx")
  @@index([action, at], map: "service_admin_audit_events_action_at_idx")
  @@map("service_admin_audit_events")
}

model ServiceAdminImpersonation {
  id              String    @id
  auditEventId    String?   @map("audit_event_id")
  approvalId      String?   @map("approval_id")
  tenantId        String    @map("tenant_id")
  tenantName      String    @map("tenant_name")
  userId          String?   @map("user_id")
  userName        String?   @map("user_name")
  mode            String
  startedAt       DateTime  @map("started_at") @db.Timestamptz(3)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(3)
  durationMinutes Int       @map("duration_minutes")
  banner          String
  stoppedAt       DateTime? @map("stopped_at") @db.Timestamptz(3)
  stopAuditEvent  Json?     @map("stop_audit_event")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([approvalId], map: "service_admin_impersonations_approval_id_idx")
  @@index([tenantId, userId, stoppedAt, expiresAt], map: "service_admin_impersonations_tenant_user_active_idx")
  @@map("service_admin_impersonations")
}

model BreakGlassApproval {
  id              String   @id
  action          String
  durationMinutes Int      @map("duration_minutes")
  expiresAt       DateTime @map("expires_at") @db.Timestamptz(3)
  status          String
  target          String
  tenantId        String?  @map("tenant_id")
  userId          String?  @map("user_id")
  auditEventId    String   @map("audit_event_id")
  requestedAt     DateTime @map("requested_at") @db.Timestamptz(3)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, expiresAt], map: "break_glass_approvals_status_expires_at_idx")
  @@index([tenantId, userId, requestedAt], map: "break_glass_approvals_tenant_user_requested_at_idx")
  @@map("break_glass_approvals")
}

model BillingTenantState {
  id                 String                    @id
  name               String
  status             String
  planId             String                    @map("plan_id")
  users              Int
  workspaces         Int
  monthlyRevenue     Int                       @map("monthly_revenue")
  arr                Int
  region             String
  owner              String
  healthScore        Int                       @map("health_score")
  sla                String
  usage              Json
  createdAt          DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  syncJobs           BillingSyncJob[]
  quotaLedgerEntries BillingQuotaLedgerEntry[]
  quotaReservations  BillingQuotaReservation[]
  subscriptions      BillingSubscription[]
  invoices           BillingInvoice[]
  providerSyncEvents BillingProviderSyncEvent[]
  paymentRetrySchedules BillingPaymentRetrySchedule[]
  paymentDunningStates BillingPaymentDunningState[]
  reconciliationConflicts BillingReconciliationConflict[]
  paymentRetryKeys BillingPaymentRetryKey[]
  billingApprovals BillingApproval[]
  billingLegalEntities BillingLegalEntity[]
  billingTaxDocuments BillingTaxDocument[]

  @@index([planId], map: "billing_tenant_states_plan_id_idx")
  @@map("billing_tenant_states")
}

model BillingSyncJob {
  id           String             @id
  tenantId     String             @map("tenant_id")
  tenant       BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  queue        String
  status       String
  fromPlanId   String             @map("from_plan_id")
  toPlanId     String             @map("to_plan_id")
  reason       String
  actor        String
  actorName    String             @map("actor_name")
  auditEventId String             @map("audit_event_id")
  traceId      String             @map("trace_id")
  payload      Json
  attempts     Int                @default(0)
  lastError    String?            @map("last_error")
  lockedAt     DateTime?          @map("locked_at") @db.Timestamptz(3)
  nextAttemptAt DateTime?         @map("next_attempt_at") @db.Timestamptz(3)
  deadLetteredAt DateTime?        @map("dead_lettered_at") @db.Timestamptz(3)
  deadLetterReplayAuditEvents Json @default("[]") @map("dead_letter_replay_audit_events")
  publishedAt  DateTime?          @map("published_at") @db.Timestamptz(3)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([tenantId, createdAt], map: "billing_sync_jobs_tenant_id_created_at_idx")
  @@index([status, queue, createdAt], map: "billing_sync_jobs_status_queue_created_at_idx")
  @@index([status, queue, lockedAt], map: "billing_sync_jobs_status_queue_locked_at_idx")
  @@index([status, queue, nextAttemptAt], map: "billing_sync_jobs_status_queue_next_attempt_at_idx")
  @@map("billing_sync_jobs")
}

model BillingQuotaLedgerEntry {
  id                 String             @id
  tenantId           String             @map("tenant_id")
  tenant             BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId             String             @map("plan_id")
  mode               String
  resource           String
  decision           String
  requested          Int
  used               Int
  limit              Int
  projected          Int
  remainingBefore    Int                @map("remaining_before")
  remainingAfter     Int                @map("remaining_after")
  idempotencyKey     String             @unique(map: "billing_quota_ledger_entries_idempotency_key_key") @map("idempotency_key")
  requestFingerprint String             @map("request_fingerprint")
  auditEvent         Json?              @map("audit_event")
  reason             String?
  traceId            String             @map("trace_id")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([tenantId, resource, createdAt], map: "billing_quota_ledger_entries_tenant_resource_created_at_idx")
  @@index([tenantId, resource, decision, createdAt], map: "billing_quota_ledger_tenant_resource_decision_idx")
  @@index([decision, createdAt], map: "billing_quota_ledger_entries_decision_created_at_idx")
  @@map("billing_quota_ledger_entries")
}

model BillingQuotaReservation {
  id                    String             @id
  tenantId              String             @map("tenant_id")
  tenant                BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId                String             @map("plan_id")
  resource              String
  status                String
  requested             Int
  usedBefore            Int                @map("used_before")
  usedAfter             Int?               @map("used_after")
  limit                 Int
  idempotencyKey        String             @unique(map: "billing_quota_reservations_idempotency_key_key") @map("idempotency_key")
  commitIdempotencyKey  String?            @unique(map: "billing_quota_reservations_commit_idempotency_key_key") @map("commit_idempotency_key")
  releaseIdempotencyKey String?            @unique(map: "billing_quota_reservations_release_idempotency_key_key") @map("release_idempotency_key")
  requestFingerprint    String             @map("request_fingerprint")
  auditEvent            Json?              @map("audit_event")
  auditEvents           Json               @default("[]") @map("audit_events")
  traceId               String             @map("trace_id")
  lockedAt              DateTime?          @map("locked_at") @db.Timestamptz(3)
  expiresAt             DateTime           @map("expires_at") @db.Timestamptz(3)
  committedAt           DateTime?          @map("committed_at") @db.Timestamptz(3)
  releasedAt            DateTime?          @map("released_at") @db.Timestamptz(3)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([tenantId, resource, status, createdAt], map: "billing_quota_res_tenant_resource_status_created_idx")
  @@index([status, expiresAt], map: "billing_quota_reservations_status_expires_at_idx")
  @@index([status, expiresAt, lockedAt], map: "billing_quota_res_status_expires_locked_idx")
  @@map("billing_quota_reservations")
}

model BillingSubscription {
  id                     String             @id
  tenantId               String             @map("tenant_id")
  tenant                 BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider               String
  providerCustomerId     String             @map("provider_customer_id")
  providerSubscriptionId String             @map("provider_subscription_id")
  planId                 String             @map("plan_id")
  status                 String
  billingPeriod          String             @map("billing_period")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  currency               String
  seats                  Int
  unitAmountMonthly      Int                @map("unit_amount_monthly")
  currentPeriodStart     DateTime           @map("current_period_start") @db.Timestamptz(3)
  currentPeriodEnd       DateTime           @map("current_period_end") @db.Timestamptz(3)
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  invoices               BillingInvoice[]

  @@unique([provider, providerSubscriptionId], map: "billing_subscriptions_provider_subscription_key")
  @@index([tenantId, status, updatedAt], map: "billing_subscriptions_tenant_status_updated_at_idx")
  @@index([tenantId, updatedAt], map: "billing_subscriptions_tenant_updated_at_idx")
  @@map("billing_subscriptions")
}

model BillingInvoice {
  id                String              @id
  tenantId          String              @map("tenant_id")
  tenant            BillingTenantState  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId    String?             @map("subscription_id")
  subscription      BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  provider          String
  providerInvoiceId String              @map("provider_invoice_id")
  status            String
  paymentStatus     String              @map("payment_status")
  currency          String
  amountDue         Int                 @map("amount_due")
  amountPaid        Int                 @map("amount_paid")
  dueAt             DateTime            @map("due_at") @db.Timestamptz(3)
  paidAt            DateTime?           @map("paid_at") @db.Timestamptz(3)
  hostedInvoiceUrl  String?             @map("hosted_invoice_url")
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([provider, providerInvoiceId], map: "billing_invoices_provider_invoice_key")
  @@index([tenantId, status, dueAt], map: "billing_invoices_tenant_status_due_at_idx")
  @@index([tenantId, updatedAt], map: "billing_invoices_tenant_updated_at_idx")
  @@map("billing_invoices")
}

model BillingProviderSyncEvent {
  id                 String             @id
  tenantId           String             @map("tenant_id")
  tenant             BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider           String
  eventType          String             @map("event_type")
  status             String
  idempotencyKey     String             @unique(map: "billing_provider_sync_events_idempotency_key_key") @map("idempotency_key")
  requestFingerprint String             @map("request_fingerprint")
  syncJobId          String             @map("sync_job_id")
  traceId            String             @map("trace_id")
  payload            Json
  auditEvents        Json               @default("[]") @map("audit_events")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([tenantId, provider, createdAt], map: "billing_provider_sync_events_tenant_provider_created_at_idx")
  @@index([status, createdAt], map: "billing_provider_sync_events_status_created_at_idx")
  @@map("billing_provider_sync_events")
}

model BillingPaymentRetrySchedule {
  scheduleId         String             @map("schedule_id")
  tenantId           String             @map("tenant_id")
  tenant             BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId          String             @map("invoice_id")
  provider           String
  providerInvoiceId  String             @map("provider_invoice_id")
  idempotencyKey     String             @unique(map: "billing_payment_retry_schedules_idempotency_key_key") @map("idempotency_key")
  requestFingerprint String             @map("request_fingerprint")
  status             String
  attempt            Int                @default(0)
  maxAttempts        Int                @map("max_attempts")
  nextAttemptAt      DateTime           @map("next_attempt_at") @db.Timestamptz(3)
  lastAttemptAt      DateTime?          @map("last_attempt_at") @db.Timestamptz(3)
  traceId            String             @map("trace_id")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([tenantId, scheduleId], map: "billing_payment_retry_schedules_pkey")
  @@index([tenantId, invoiceId, status, nextAttemptAt], map: "billing_retry_sched_tenant_invoice_status_next_idx")
  @@index([tenantId, status, nextAttemptAt], map: "billing_retry_sched_tenant_status_next_idx")
  @@index([provider, providerInvoiceId], map: "billing_retry_sched_provider_invoice_idx")
  @@map("billing_payment_retry_schedules")
}

model BillingPaymentDunningState {
  dunningId          String             @map("dunning_id")
  tenantId           String             @map("tenant_id")
  tenant             BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId          String             @map("invoice_id")
  subscriptionId     String?            @map("subscription_id")
  provider           String
  providerInvoiceId  String             @map("provider_invoice_id")
  idempotencyKey     String             @unique(map: "billing_payment_dunning_states_idempotency_key_key") @map("idempotency_key")
  requestFingerprint String             @map("request_fingerprint")
  stage              String
  status             String
  failedAttempts     Int                @default(0) @map("failed_attempts")
  lastFailureAt      DateTime?          @map("last_failure_at") @db.Timestamptz(3)
  nextActionAt       DateTime?          @map("next_action_at") @db.Timestamptz(3)
  traceId            String             @map("trace_id")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([tenantId, dunningId], map: "billing_payment_dunning_states_pkey")
  @@index([tenantId, invoiceId, status, updatedAt], map: "billing_dunning_tenant_invoice_status_updated_idx")
  @@index([tenantId, status, nextActionAt], map: "billing_dunning_tenant_status_next_action_idx")
  @@index([provider, providerInvoiceId], map: "billing_dunning_provider_invoice_idx")
  @@map("billing_payment_dunning_states")
}

model BillingReconciliationConflict {
  conflictId         String             @map("conflict_id")
  tenantId           String             @map("tenant_id")
  tenant             BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId          String             @map("invoice_id")
  provider           String
  providerInvoiceId  String             @map("provider_invoice_id")
  idempotencyKey     String             @unique(map: "billing_reconciliation_conflicts_idempotency_key_key") @map("idempotency_key")
  requestFingerprint String             @map("request_fingerprint")
  reason             String
  severity           String
  status             String
  expected           Json               @default("{}")
  actual             Json               @default("{}")
  resolution         String?
  resolvedAt         DateTime?          @map("resolved_at") @db.Timestamptz(3)
  detectedAt         DateTime           @map("detected_at") @db.Timestamptz(3)
  traceId            String             @map("trace_id")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([tenantId, conflictId], map: "billing_reconciliation_conflicts_pkey")
  @@index([tenantId, invoiceId, status, detectedAt], map: "billing_recon_conflicts_tenant_invoice_status_detected_idx")
  @@index([tenantId, status, severity, updatedAt], map: "billing_recon_conflicts_tenant_status_severity_updated_idx")
  @@index([provider, providerInvoiceId], map: "billing_recon_conflicts_provider_invoice_idx")
  @@map("billing_reconciliation_conflicts")
}

model BillingPaymentRetryKey {
  retryKeyId         String             @map("retry_key_id")
  tenantId           String             @map("tenant_id")
  tenant             BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId          String             @map("invoice_id")
  scheduleId         String?            @map("schedule_id")
  provider           String
  providerInvoiceId  String             @map("provider_invoice_id")
  idempotencyKey     String             @unique(map: "billing_payment_retry_keys_idempotency_key_key") @map("idempotency_key")
  requestFingerprint String             @map("request_fingerprint")
  status             String
  attempt            Int                @default(0)
  result             Json               @default("{}")
  firstAttemptAt     DateTime           @map("first_attempt_at") @db.Timestamptz(3)
  lastAttemptAt      DateTime?          @map("last_attempt_at") @db.Timestamptz(3)
  traceId            String             @map("trace_id")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@id([tenantId, retryKeyId], map: "billing_payment_retry_keys_pkey")
  @@index([tenantId, invoiceId, status, firstAttemptAt], map: "billing_retry_keys_tenant_invoice_status_first_idx")
  @@index([tenantId, status, updatedAt], map: "billing_retry_keys_tenant_status_updated_idx")
  @@index([provider, providerInvoiceId], map: "billing_retry_keys_provider_invoice_idx")
  @@map("billing_payment_retry_keys")
}

model BillingApproval {
  approvalId         String             @map("approval_id")
  tenantId           String             @map("tenant_id")
  tenant             BillingTenantState @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjectType        String             @map("subject_type")
  subjectId          String             @map("subject_id")
  status             String
  reason             String
  requestFingerprint String             @map("request_fingerprint")
  requestedBy        String             @map("requested_by")
  requestedByName    String             @map("requested_by_name")
  decidedBy          String?            @map("decided_by")
