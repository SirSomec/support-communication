NODE_ENV=development
PORT=4100
SERVICE_NAME=api-gateway
API_VERSION=v1
AUTOMATION_STORE_FILE=.runtime/automation-store.json
DATABASE_URL=postgresql://support:support@127.0.0.1:5432/support_communication
IDENTITY_REPOSITORY=json
IDENTITY_STORE_FILE=.runtime/identity-store.json
BILLING_REPOSITORY=json
CONVERSATION_REPOSITORY=json
WORKSPACE_REPOSITORY=json
ROUTING_REPOSITORY=json
INTEGRATION_STORE_FILE=.runtime/integration-store.json
OPERATIONS_STORE_FILE=.runtime/operations-store.json
PLATFORM_STORE_FILE=.runtime/platform-store.json
REPORT_STORE_FILE=.runtime/report-store.json
REDIS_URL=redis://127.0.0.1:6379
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=support-communication-local
