{
  "name": "support-communication",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "backend:lint": "cd backend && npm run lint",
    "backend:typecheck": "cd backend && npm run typecheck",
    "backend:test": "cd backend && npm test",
    "backend:test:integration": "cd backend && npm run test:integration",
    "backend:tenant-isolation:verify": "cd backend && npm run tenant-isolation:verify",
    "backend:audit-immutability:verify": "cd backend && npm run audit-immutability:verify",
    "backend:redaction:runtime-smoke": "cd backend && npm run redaction:runtime-smoke",
    "backend:test:runtime": "npm run backend:redaction:runtime-smoke && node --test tests/backend-runtime.test.js",
    "backend:smoke:postgres": "cd backend && npm run smoke:postgres",
    "backend:release:checklist": "cd backend && npm run release:checklist",
    "backend:outbox:worker:once": "cd backend && npm run outbox:worker:once",
    "backend:billing:worker:once": "cd backend && npm run billing:worker:once",
    "backend:outbox:bullmq": "cd backend && npm run start:outbox-bullmq-worker",
    "backend:billing:bullmq": "cd backend && npm run start:billing-bullmq-worker",
    "backend:build": "cd backend && npm run build",
    "test:api-client": "node --test tests/api-client.test.js",
    "test:backend-api-smoke": "node --test tests/backend-api-smoke.test.js",
    "test:services": "node --test tests/backend-services.test.js",
    "test:smoke": "playwright test tests/smoke.spec.js"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}
