// Source catalog for the grounded AI bot.  This is deliberately separate from
// KnowledgeArticle: articles remain the editorial workspace, while a source
// may be a document, a fetched URL or a read-only MCP integration.
//
// Values for status/readiness/approvalStatus are kept as strings to make this
// additive migration compatible with the existing database conventions.  The
// application contract lives in knowledge-sources/knowledge-source.types.ts.
model KnowledgeSource {
  id             String    @id
  tenantId       String    @map("tenant_id")
  kind           String
  title          String
  status         String    @default("draft")
  readiness      String    @default("not_ready")
  approvalStatus String    @default("pending") @map("approval_status")
  owner          String
  sourceRef      String?   @map("source_ref")
  sourceConfig   Json      @default("{}") @map("source_config")
  metadata       Json      @default("{}")
  version        Int       @default(1)
  contentChecksum String?  @map("content_checksum")
  approvedBy     String?   @map("approved_by")
  approvedAt     DateTime? @map("approved_at") @db.Timestamptz(3)
  lastIngestedAt DateTime? @map("last_ingested_at") @db.Timestamptz(3)
  lastIndexedAt  DateTime? @map("last_indexed_at") @db.Timestamptz(3)
  failedAt       DateTime? @map("failed_at") @db.Timestamptz(3)
  failureCode    String?   @map("failure_code")
  disabledAt     DateTime? @map("disabled_at") @db.Timestamptz(3)
  archivedAt     DateTime? @map("archived_at") @db.Timestamptz(3)
  retentionUntil DateTime? @map("retention_until") @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([tenantId, id], map: "knowledge_sources_tenant_id_key")
  @@index([tenantId, status, readiness, approvalStatus], map: "knowledge_sources_tenant_lifecycle_idx")
  @@index([tenantId, kind, updatedAt], map: "knowledge_sources_tenant_kind_updated_idx")
  @@index([tenantId, approvalStatus, readiness, version], map: "knowledge_sources_tenant_retrieval_idx")
  @@map("knowledge_sources")
}

